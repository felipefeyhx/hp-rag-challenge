# ==========================================================
# HP RAG Chatbot - Environment variables
# Copy this file to `.env` and adjust if needed.
#
# Defaults target a fully-local setup where no data leaves
# the machine: an Ollama container in docker-compose serves
# both chat and embeddings.
#
# NOTE: The LLM and embedding models are fixed in code
# (backend/app/config.py) and cannot be changed via env vars.
# Changing the embedding model would invalidate the vector
# store; changing the chat model would require re-pulling
# it in docker-compose.yml too.
# ==========================================================

# -------- LLM endpoint --------
#   - Local dev on host:  http://localhost:11434/v1
#   - docker-compose:     http://ollama:11434/v1
LLM_BASE_URL=http://localhost:11434/v1
# Placeholder; local runners ignore it. Never sent externally.
LLM_API_KEY=ollama

# -------- Embeddings endpoint --------
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama

# -------- Vector store --------
CHROMA_PERSIST_DIR=/app/data/chroma
CHROMA_COLLECTION=hp_docs

# -------- Chunking --------
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# -------- Retrieval --------
# Options: "similarity" | "mmr"
RETRIEVAL_STRATEGY=mmr
RETRIEVAL_TOP_K=5
RETRIEVAL_FETCH_K=20
RETRIEVAL_MMR_LAMBDA=0.5

# -------- Chat history --------
# Previous exchanges (user + assistant pairs) sent to the prompt
HISTORY_WINDOW=6

# -------- Database --------
DATABASE_URL=sqlite:////app/data/db/chatbot.db

# -------- API --------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
